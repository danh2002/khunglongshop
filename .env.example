# TiDB Cloud MySQL-compatible connection string.
DATABASE_URL=mysql://replace-with-a-tidb-connection-string

# NextAuth signing secret and canonical application URL.
NEXTAUTH_SECRET=replace-with-a-generated-secret
NEXTAUTH_URL=http://localhost:3000

# Optional server-side API base URL; defaults to NEXTAUTH_URL.
API_BASE_URL=http://localhost:3000

# Vercel Blob read/write token for production uploads.
BLOB_READ_WRITE_TOKEN=replace-with-a-vercel-blob-write-token

# Resend API credential and verified sender identity.
RESEND_API_KEY=replace-with-a-resend-api-key
RESEND_FROM_EMAIL=replace-with-a-verified-sender@example.com

# Shared credential accepted by the game redemption API.
GAME_API_KEY=replace-with-a-generated-game-api-key

# Bearer credential used by scheduled maintenance routes.
CRON_SECRET=replace-with-a-generated-cron-secret

# Optional SMS provider settings for OTP delivery.
SMS_PROVIDER_URL=https://replace-with-an-sms-provider-endpoint
SMS_API_KEY=replace-with-an-sms-provider-api-key
SMS_FROM_NUMBER=replace-with-an-sms-sender-number
SMS_TIMEOUT_MS=10000

# Optional operational maintenance flag.
MAINTENANCE_MODE=false
