{
  "name": "electronic-ecommerce-shop-with-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently --kill-others-on-fail --names web,api \"npm:dev:web\" \"npm:dev:api\"",
    "dev:web": "next dev",
    "dev:api": "npm --prefix server start",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration --no-file-parallelism",
    "test:collector": "node scripts/verify-collector-unlock.js",
    "test:account": "node scripts/verify-account-auth.js",
    "test:admin-cms": "node scripts/verify-admin-cms-phase1.js",
    "seed:vanie": "node scripts/seed-vanie-collection.js",
    "seed:ricon": "node scripts/seed-ricon-pool.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:preflight:cms": "node scripts/preflight-cms-visual-logic.js",
    "db:repair:redemption-orders": "node scripts/repair-redemption-order-orphans.js",
    "db:backfill:order-snapshots": "node scripts/backfill-order-snapshots.js",
    "db:reconcile:redemption-status": "node scripts/reconcile-redemption-status.js"
  },
  "dependencies": {
    "@headlessui/react": "^1.7.18",
    "@prisma/client": "^6.16.1",
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/typography": "^0.5.10",
    "@types/bcryptjs": "^2.4.6",
    "@types/react-slick": "^0.23.13",
    "bcryptjs": "^2.4.3",
    "date-fns": "^4.1.0",
    "dompurify": "^3.0.8",
    "express-fileupload": "^1.5.0",
    "express-rate-limit": "^8.1.0",
    "flowbite-react": "^0.7.2",
    "framer-motion": "^12.40.0",
    "nanoid": "^5.0.6",
    "next": "^15.5.19",
    "next-auth": "^4.24.11",
    "react": "^18.3.1",
    "react-apexcharts": "^1.4.1",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.4.1",
    "react-icons": "^5.0.1",
    "react-slick": "^0.30.2",
    "resend": "^6.14.0",
    "slick-carousel": "^1.8.1",
    "styled-components": "^6.4.2",
    "svgmap": "^2.10.1",
    "zod": "^3.22.4",
    "zustand": "^4.5.1"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^24.3.3",
    "@types/react": "^18.3.24",
    "@types/react-dom": "^18.3.7",
    "@types/supertest": "^7.2.0",
    "autoprefixer": "^10.0.1",
    "concurrently": "^9.2.1",
    "daisyui": "^4.7.2",
    "eslint": "^8",
    "eslint-config-next": "^15.5.19",
    "jsdom": "^29.1.1",
    "postcss": "^8",
    "prisma": "^6.16.1",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.3.0",
    "typescript": "^5.9.2",
    "vitest": "^4.1.8"
  }
}
